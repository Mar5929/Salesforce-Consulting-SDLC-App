# Database (Neon)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Clerk
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Required for Salesforce/Jira token encryption. Generate with: openssl rand -hex 32
SF_TOKEN_ENCRYPTION_KEY=

# Salesforce Connected App (Phase 4)
SF_CONNECTED_APP_CLIENT_ID=your-connected-app-client-id
SF_CONNECTED_APP_CLIENT_SECRET=your-connected-app-client-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Inngest (optional for local dev)
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# S3 / R2 Storage (Phase 5 - Document Generation)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1
# AWS_S3_ENDPOINT is only required for Cloudflare R2. Omit for AWS S3.
AWS_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Voyage AI (Phase 2 - Embeddings)
# Optional: search gracefully falls back to full-text when not configured
VOYAGE_API_KEY=your-voyage-api-key
